        /* 300 level – mid blue */
        .block.is-available[data-section-name="303"],.block.is-available[data-section-name="304"],.block.is-available[data-section-name="305"],.block.is-available[data-section-name="306"],.block.is-available[data-section-name="307"],.block.is-available[data-section-name="308"],.block.is-available[data-section-name="309"],.block.is-available[data-section-name="310"],.block.is-available[data-section-name="311"],.block.is-available[data-section-name="312"],.block.is-available[data-section-name="313"],.block.is-available[data-section-name="314"],.block.is-available[data-section-name="315"],.block.is-available[data-section-name="316"],.block.is-available[data-section-name="317"],.block.is-available[data-section-name="318"],.block.is-available[data-section-name="319"],.block.is-available[data-section-name="320"],.block.is-available[data-section-name="330"],.block.is-available[data-section-name="331"],.block.is-available[data-section-name="332"],.block.is-available[data-section-name="333"],.block.is-available[data-section-name="334"],.block.is-available[data-section-name="335"],.block.is-available[data-section-name="336"],.block.is-available[data-section-name="337"],.block.is-available[data-section-name="338"],.block.is-available[data-section-name="339"],.block.is-available[data-section-name="340"],.block.is-available[data-section-name="341"],.block.is-available[data-section-name="342"],.block.is-available[data-section-name="343"],.block.is-available[data-section-name="344"],.block.is-available[data-section-name="345"],.block.is-available[data-section-name="346"],.block.is-available[data-section-name="347"] { fill: rgba(74,144,226,0.82); }

        /* 200 level – dark blue */
        .block.is-available[data-section-name="201"],.block.is-available[data-section-name="202"],.block.is-available[data-section-name="203"],.block.is-available[data-section-name="204"],.block.is-available[data-section-name="205"],.block.is-available[data-section-name="206"],.block.is-available[data-section-name="207"],.block.is-available[data-section-name="208"],.block.is-available[data-section-name="218"],.block.is-available[data-section-name="219"],.block.is-available[data-section-name="220"],.block.is-available[data-section-name="221"],.block.is-available[data-section-name="229"],.block.is-available[data-section-name="230"],.block.is-available[data-section-name="231"],.block.is-available[data-section-name="232"],.block.is-available[data-section-name="242"],.block.is-available[data-section-name="243"],.block.is-available[data-section-name="244"],.block.is-available[data-section-name="245"],.block.is-available[data-section-name="246"],.block.is-available[data-section-name="247"],.block.is-available[data-section-name="248"] { fill: rgba(26,79,196,0.82); }

        /* 100 level – navy */
        .block.is-available[data-section-name="101"],.block.is-available[data-section-name="102"],.block.is-available[data-section-name="103"],.block.is-available[data-section-name="104"],.block.is-available[data-section-name="105"],.block.is-available[data-section-name="106"],.block.is-available[data-section-name="107"],.block.is-available[data-section-name="108"],.block.is-available[data-section-name="117"],.block.is-available[data-section-name="118"],.block.is-available[data-section-name="119"],.block.is-available[data-section-name="127"],.block.is-available[data-section-name="128"],.block.is-available[data-section-name="129"],.block.is-available[data-section-name="130"],.block.is-available[data-section-name="138"],.block.is-available[data-section-name="139"],.block.is-available[data-section-name="140"],.block.is-available[data-section-name="141"],.block.is-available[data-section-name="142"],.block.is-available[data-section-name="143"],.block.is-available[data-section-name="144"] { fill: rgba(10,42,110,0.88); }

        /* CLUB sections – purple-blue */
        .block.is-available[data-section-name^="CLUB"] { fill: rgba(90,90,200,0.82); }

        /* PIT sections – teal green */
        .block.is-available[data-section-name^="PIT"] { fill: rgba(29,158,117,0.88); }

        /* Floor sections (A/B/C) – pale with dark text */
        .block.is-available[data-section-name^="A"],.block.is-available[data-section-name^="B"],.block.is-available[data-section-name="C3"],.block.is-available[data-section-name="C3 ADA"] { fill: rgba(220,236,255,0.88); }

        /* Labels */
        .label {
          fill: rgba(255,255,255,0.95);
          font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
          font-weight: 700;
          pointer-events: none;
          text-shadow: 0 1px 3px rgba(0,0,0,0.6);
        }
      </style>
      
      <!-- SEAT STATUS COLORS -->
      <style>
        /* Seat Status Color Coding */
        .seat {
          fill: #a8c8f0;
          stroke: #4a90e2;
          stroke-width: 0.5;
          transition: fill 0.2s ease, filter 0.2s ease;
          cursor: pointer;
        }
        
        .seat:hover:not(.sold):not(.unavailable) {
          fill: #1a4fc4;
          filter: drop-shadow(0 0 3px rgba(26, 79, 196, 0.6));
        }
        
        .seat.selected {
          fill: #0a2a6e;
          stroke: #ffffff;
          stroke-width: 1.5;
          filter: drop-shadow(0 0 4px rgba(10, 42, 110, 0.8));
        }
        
        .seat.sold {
          fill: #d0d0d0;
          stroke: #999;
          cursor: not-allowed;
          opacity: 0.6;
        }
        
        .seat.unavailable {
          fill: #e8c8c8;
          stroke: #c0a0a0;
          cursor: not-allowed;
          opacity: 0.5;
        }
        
        /* Custom Premium Seats (g elements) */
        .seat.is-custom circle {
          fill: #4a90e2;
          stroke: #1a4fc4;
          stroke-width: 1;
        }
        
        .seat.is-custom:hover:not(.sold):not(.unavailable) circle {
          fill: #1a4fc4;
          filter: drop-shadow(0 0 3px rgba(26, 79, 196, 0.6));
        }
        
        .seat.is-custom.selected circle {
          fill: #0a2a6e;
          stroke: #ffffff;
          stroke-width: 2;
        }
        
        .seat.is-custom.sold circle {
          fill: #d0d0d0;
          opacity: 0.6;
        }
      </style>

      <!-- SEAT TOOLTIP -->
      <style>
        #seatTooltip {
          position: fixed;
          background: rgba(10, 42, 110, 0.95);
          color: #ffffff;
          padding: 10px 12px;
          border-radius: 6px;
          font-size: 12px;
          font-weight: 600;
          pointer-events: none;
          z-index: 1000;
          display: none;
          white-space: nowrap;
          box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
          border: 1px solid rgba(255, 255, 255, 0.2);
        }
        
        #seatTooltip.show {
          display: block;
        }
        
        #seatTooltip .tooltip-row {
          display: flex;
          justify-content: space-between;
          gap: 12px;
        }
      </style>
    </defs>
    <g class="polygons">
  <div class="event-info">
    <h1>Morgan Wallen</h1>
    <div class="event-meta"><strong>FRI APR 10, 2026</strong> · 5:15 PM | U.S. Bank Stadi...</div>
  </div>
  <div class="avatar"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></div>
</div>

<!-- FILTER BAR -->
<div class="filter-bar">
  <div class="filter-icon">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="2">
      <line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="11" y1="18" x2="13" y2="18"/>
    </svg>
  </div>
  <div class="price-pill">
    Price Range: $81 – $1,705 <span>▼</span>
  </div>
  <div class="ticket-types-btn">Ticket Types (3)</div>
</div>

<!-- PRICE RANGE SLIDER (Mobile) -->
<div class="ticket-price-range" style="display: flex; align-items: center; justify-content: space-between; padding: 16px; background: #fff; border-bottom: 1px solid #eee;">
  <span class="price-range-label">$152</span>
  <div style="flex:1;position:relative;height:4px;background:#ddd;border-radius:2px;margin:0 8px;">
    <div style="position:absolute;left:0;right:0;height:4px;background:#026cdf;border-radius:2px;"></div>
    <div style="position:absolute;left:-8px;top:50%;transform:translateY(-50%);width:16px;height:16px;border-radius:50%;background:#fff;border:2px solid #026cdf;"></div>
    <div style="position:absolute;right:-8px;top:50%;transform:translateY(-50%);width:16px;height:16px;border-radius:50%;background:#fff;border:2px solid #026cdf;"></div>
  </div>
  <span class="price-max-label">$1,008+</span>
</div>

<!-- SORT TABS (Mobile) -->
<div class="ticket-sort-tabs" style="display: flex; background: #fff; border-bottom: 1px solid #eee; padding: 0;">
  <div class="sort-tab active" style="flex:1; padding: 12px; text-align: center; font-size: 12px; font-weight: 600; border-bottom: 3px solid #026cdf; color: #026cdf;">LOWEST PRICE</div>
  <div class="sort-tab" style="flex:1; padding: 12px; text-align: center; font-size: 12px; font-weight: 600; border-bottom: 3px solid transparent; color: #999;">BEST SEATS</div>
</div>

<!-- INFO BANNER (Mobile) -->
<div class="wai-banner" style="padding: 12px 16px; background: #e8f2ff; border-bottom: 1px solid #c8dcf5; font-size: 12px; color: #1a4fc4;">
  <strong>We're All In:</strong> Prices include fees (before taxes).
</div>

<!-- VIP PACKAGES (Mobile) -->
<div class="vip-row" style="padding: 14px 16px; background: #fff; border-bottom: 1px solid #eee; display: flex; justify-content: space-between; align-items: center;">
  <div style="display: flex; align-items: center; gap: 8px;">
    <span style="font-size: 18px; color: #f0c040;">★</span>
    <span style="font-size: 14px; font-weight: 700;">VIP Packages</span>
  </div>
  <span style="font-size: 13px; color: #026cdf; font-weight: 600;">More Info</span>
</div>

<!-- STADIUM MAP -->
<div class="map-container" id="mapContainer">
  <div class="map-tooltip" id="mapTooltip"></div>
  <svg class="stadium-svg" viewBox="0 0 10240 7680" xmlns="http://www.w3.org/2000/svg"
       style="width:100%;height:100%;position:absolute;top:0;left:0;background-image:url('https://mapsapi.tmol.io/maps/geometry/image/72/29/722924?removeFilters=ISM_Shadow&avertaFonts=true&app=PRD2663_EDP_NA');background-size:100% 100%;background-repeat:no-repeat;">
    <defs>
      <style>
        /* Base section styles */
        .block { cursor: pointer; stroke: rgba(255,255,255,0.5); stroke-width: 10; transition: all 0.12s; }
        .block.is-available:hover { opacity: 0.8; stroke: #fff; stroke-width: 14; }
        .block.sel { stroke: #ffe000 !important; stroke-width: 22 !important; opacity: 1 !important; filter: drop-shadow(0 0 6px rgba(255,224,0,0.7)); }

        /* Unavailable – greyed out, no pointer */
        .block:not(.is-available) { fill: rgba(160,174,190,0.45); cursor: default; stroke: rgba(255,255,255,0.15); }
        .block:not(.is-available):hover { opacity: 1; }

        /* 400 level – light blue */
