  <!-- Map toggle -->
  <div class="map-toggle">🗺</div>

<!-- SEAT TOOLTIP -->
<div id="seatTooltip"></div>

<!-- MAP TOOLTIP (Mobile Section) -->
<div id="mapTooltip" class="map-tooltip"></div>

<!-- INFO BANNER -->

<!-- BOTTOM SHEET: default state -->
<div class="bottom-sheet" id="bottomSheet">
  <div class="sheet-handle"></div>
  <div class="sheet-content" id="sheetDefault">
    <h2>Pick Your Tickets on Map</h2>
    <p>Great tickets available!</p>
  </div>

  <!-- Ticket list (shown on section click) -->
  <div class="ticket-list" id="ticketList">
    <div class="sheet-title-row">
      <button class="back-btn" id="backBtn">←</button>
      <span class="sheet-section-name" id="sectionName">Section</span>
    </div>
    <div id="ticketItems" style="padding: 12px 16px 0;"></div>
    
    <!-- Purchase summary (shown when seats are selected) -->
    <div id="purchaseSummary" class="purchase-summary" style="display: none; margin: 16px 0 12px;">
      <div class="purchase-summary-row">
        <span>Seats:</span>
        <span id="selectedSeats">-</span>
      </div>
      <div class="purchase-summary-row">
        <span>Quantity:</span>
        <span id="seatCount">0</span>
      </div>
      <div class="purchase-summary-row total">
        <span>Total:</span>
        <span id="totalPrice">$0</span>
      </div>
    </div>
  </div>

  <!-- Purchase button (shown when seats selected) -->
  <button class="purchase-btn" id="purchaseBtn" style="display: none;" disabled>
    Continue to Checkout
  </button>
</div>

<div class="home-indicator"></div>

<script>
  // ── STATE ──────────────────────────────────────────────────
  var checkoutArray = [];
  var quantityMultiplier = 1;

  // ── HELPERS ────────────────────────────────────────────────
  function getPrice(name) {
    if (!name) return 150;
    if (name.startsWith('PIT'))  return 680;
    if (/^[ABC]/.test(name))     return 1200;
    if (name.startsWith('CLUB')) return 350;
    const n = parseInt(name);
    if (n >= 400) return 81;
    if (n >= 300) return 130;
    if (n >= 200) return 210;
    if (n >= 100) return 380;
    return 150;
  }

  // ── CHECKOUT BAR & CART MATH ────────────────────────────────
  function updateCheckoutUI() {
    const count = checkoutArray.length;
    const baseTotal = checkoutArray.reduce((s, t) => s + t.price, 0);
    const grandTotal = baseTotal * quantityMultiplier;

    const bar = document.getElementById('checkout-bar');
    const counter = document.getElementById('checkout-counter');
    const totalEl = document.getElementById('checkout-total');
    const ps = document.getElementById('purchaseSummary');
    const pb = document.getElementById('purchaseBtn');

    if (count === 0) { 
      if(bar) bar.classList.add('hidden'); 
      if(ps) ps.style.display = 'none';
      if(pb) pb.style.display = 'none';
      return; 
    }
    
    // Update Bottom Fixed Bar
    if(bar) bar.classList.remove('hidden');
    if(counter) counter.textContent = count;
    if(totalEl) totalEl.textContent = `$${grandTotal.toFixed(2)}`;

    // Update Bottom Sheet Summary
    if (ps) {
      ps.style.display = 'block';
      const seats = checkoutArray.map(t => `Sec ${t.section} Row ${t.row}`);
      document.getElementById('selectedSeats').textContent = seats.join(', ');
      document.getElementById('seatCount').textContent = count;
      document.getElementById('totalPrice').textContent = `$${grandTotal.toLocaleString()}`;
    }
    if (pb) {
      pb.style.display = 'block';
      pb.disabled = false;
    }
  }

  // ── ROUTING ─────────────────────────────────────────────────
  function routeToCheckout() {
    if (checkoutArray.length === 0) {
      alert('Please select seats first');
      return;
    }
    localStorage.setItem('concertCart', JSON.stringify(checkoutArray));
    localStorage.setItem('concertQuantity', quantityMultiplier.toString());
    window.location.href = 'checkout.html';
  }

  // ── EVENT DELEGATION: TICKET CLICKING ───────────────────────
  document.addEventListener('click', function(e) {
    const ticketItem = e.target.closest('.ticket-item, .desktop-ticket-item');
    if (!ticketItem) return;

    e.preventDefault();
    const id = ticketItem.dataset.ticketId;
    const idx = checkoutArray.findIndex(t => t.id === id);

    if (idx >= 0) {
      checkoutArray.splice(idx, 1);
      ticketItem.classList.remove('active', 'selected');
    } else {
      checkoutArray.push({
        id: id,
        section: ticketItem.dataset.section,
        row: ticketItem.dataset.row,
        price: parseInt(ticketItem.dataset.price)
      });
      ticketItem.classList.add('active', 'selected');
    }
    updateCheckoutUI();
  });

  // ── INITIALIZATION & LISTENERS ──────────────────────────────
  document.addEventListener('DOMContentLoaded', () => {
    const quantitySelector = document.getElementById('quantity-selector');
    if (quantitySelector) {
      quantitySelector.addEventListener('change', (e) => {
        quantityMultiplier = parseInt(e.target.value);
        updateCheckoutUI();
      });
    }

    const payBtn = document.getElementById('checkout-pay-btn');
    if (payBtn) payBtn.onclick = routeToCheckout;
    
    const purchaseBtn = document.getElementById('purchaseBtn');
    if (purchaseBtn) purchaseBtn.onclick = routeToCheckout;
  });

  // ── MOBILE SORT TABS ───────────────────────────────────────
  ['mSortPrice', 'mSortBest'].forEach(id => {
    document.getElementById(id)?.addEventListener('click', function() {
      document.querySelectorAll('.mobile-sort-tabs .sort-tab').forEach(t => t.classList.remove('active'));
      this.classList.add('active');
    });
  });

  // ── MAP SECTION CLICK (MOBILE) ─────────────────────────────
  var sections = document.querySelectorAll('.map-section');
  var mapTooltip = document.getElementById('mapTooltip');
  var sheetDefault = document.getElementById('sheetDefault');
  var ticketList = document.getElementById('ticketList');
  var sectionNameEl = document.getElementById('sectionName');
  var ticketItems = document.getElementById('ticketItems');
  var backBtn = document.getElementById('backBtn');

  sections.forEach(section => {
    if (!section.classList.contains('is-available')) return;

    section.addEventListener('click', () => {
      const name = section.dataset.sectionName;
      const basePrice = getPrice(name); // FIX: Already an integer

      sections.forEach(s => s.classList.remove('sel'));
      section.classList.add('sel');

      if(sectionNameEl) sectionNameEl.textContent = 'Section ' + name;
      if(sheetDefault) sheetDefault.style.display = 'none';
      if(ticketList) ticketList.classList.add('active');

      const rows = ['Row 1', 'Row 4', 'Row 8', 'Row 12'];
      const avails = [2, 4, 2, 6];

      if(ticketItems) {
        ticketItems.innerHTML = rows.map((row, i) => {
          const itemPrice = basePrice + i * 15;
          const ticketId = `ticket-${name}-${row.replace(/\s/g, '')}`;
          const inCart = checkoutArray.some(t => t.id === ticketId);
          return `
            <div class="ticket-item${inCart ? ' active' : ''}"
                 data-ticket-id="${ticketId}"
                 data-section="${name}"
                 data-row="${row}"
                 data-price="${itemPrice}">
              <div class="ticket-item-left">
                <div class="ticket-section">Section ${name}</div>
                <div class="ticket-desc">${row}</div>
                <div class="ticket-avail">${avails[i]} tickets left</div>
              </div>
              <div class="ticket-price">$${itemPrice.toLocaleString()}</div>
            </div>`;
        }).join('');
      }

      if(mapTooltip) {
        mapTooltip.textContent = `Section ${name} · $${basePrice}+`;
        mapTooltip.classList.add('show');
        setTimeout(() => mapTooltip.classList.remove('show'), 2000);
      }
    });
  });

  if(backBtn) {
    backBtn.addEventListener('click', () => {
      if(sheetDefault) sheetDefault.style.display = '';
      if(ticketList) ticketList.classList.remove('active');
      sections.forEach(s => s.classList.remove('sel'));
      if(mapTooltip) mapTooltip.classList.remove('show');
    });
  }
</script>

<!-- Backend Configuration & Payment Gateway System -->

<!-- ============================================
     FIXED CHECKOUT BAR (Bottom of Page)
============================================ -->
<div id="checkout-bar" class="hidden">
  <div class="checkout-info">
    <span><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 6px;"><path d="M4 7h16v3.5a2.5 2.5 0 0 0 0 5V19H4v-3.5a2.5 2.5 0 0 0 0-5V7z"></path></svg>Selected:</span>
    <span id="checkout-counter">0</span>
    <span>Seats × </span>
    <select id="quantity-selector" style="padding: 4px 8px; border-radius: 4px; border: 1px solid #ccc; background: white; font-weight: 600;">
      <option value="1" selected>1</option>
      <option value="2">2</option>
      <option value="3">3</option>
      <option value="4">4</option>
      <option value="5">5</option>
      <option value="6">6</option>
      <option value="7">7</option>
      <option value="8">8</option>
    </select>
    <span>= </span>
    <span id="checkout-total">$0.00</span>
  </div>
  <button id="checkout-pay-btn">Pay Now</button>
</div>

<!-- ============================================
     CHECKOUT MODAL (Itemized List + Cash App)
============================================ -->
</body>
</html>
</html>